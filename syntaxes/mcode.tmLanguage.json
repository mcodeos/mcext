{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "mcode",
  "scopeName": "source.mcode",
  "fileTypes": ["mc"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#braces"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mcode",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mcode",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mcode",
          "match": "\\b(component|interface|module|enum|func|define|pub|use|as|this|pins|role|in|out|io|ps|anl|nc|label|if|else|return|true|false|null)\\b"
        },
        {
          "name": "keyword.operator.mcode",
          "match": "[-+*/%=<>!&|^~]"
        },
        {
          "name": "keyword.separator.mcode",
          "match": "[{};,\\[\\]()]"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.mcode",
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mcode",
              "match": "\\\\."
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.mcode",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.mcode",
      "patterns": [
        {
          "match": "\\b(0x[0-9a-fA-F]+|[0-9]+\\.?[0-9]*([eE][+-]?[0-9]+)?)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.mcode",
          "match": "\\b(HIGH|LOW|NC)\\b"
        },
        {
          "name": "support.type.mcode",
          "match": "\\b(UV\\.(VOLT|AMP|CAP|IND|TIME|LEN|WAT|OHM|TEMP|HZ|DB|PPM|PERCENT|BAUD|DATASIZE|SPS|SIEMENS|RESPONSIVITY|ANGLE|ANGULAR_RATE|ENERGY|EFIELD|HFIELD|FLUX|BFIELD|SLEW|NOISE))\\b"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.mcode",
      "patterns": [
        {
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "match": "\\b[a-z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "braces": {
      "patterns": [
        {
          "name": "meta.brace.curly.mcode",
          "match": "[{}]"
        },
        {
          "name": "meta.brace.square.mcode",
          "match": "[\\[\\]]"
        },
        {
          "name": "meta.brace.round.mcode",
          "match": "[()]"
        }
      ]
    }
  }
}
